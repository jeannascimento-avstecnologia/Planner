# Exemplo: nginx como reverse proxy TLS na LAN (Cenário A seguro).
# Copie para /etc/nginx/sites-available/agify e ajuste server_name + certificados.
#
# Pre-requisitos:
# - Next.js escutando apenas em 127.0.0.1:3001 (PM2)
# - Certificado TLS (mkcert ou CA interna) em /etc/ssl/agify/
# - NEXT_PUBLIC_APP_URL=https://agify.suaempresa.local (mesmo host abaixo)
#
# Runbook: docs/70-ops/linux-lan-secure-deploy.md
#
# IMPORTANTE: Connection "upgrade" fixo em todo request quebra POST (Server Actions -> 502).
# Use o map abaixo e proxy_set_header Connection $connection_upgrade.

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# Redireciona HTTP -> HTTPS (opcional; remova se nao usar porta 80)
server {
    listen 80;
    listen [::]:80;
    server_name agify.suaempresa.local;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name agify.suaempresa.local;

    # Ajuste os caminhos do certificado (mkcert ou CA interna)
    ssl_certificate     /etc/ssl/agify/fullchain.pem;
    ssl_certificate_key /etc/ssl/agify/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # Nao exponha versao do nginx
    server_tokens off;

    # Limite de corpo (uploads vao para Cloudinary via API assinada)
    client_max_body_size 4m;

    # Chunks Next.js: cache longo (hash no nome = immutable)
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # HTML/API: nunca cachear shell pos-deploy (evita ChunkLoadError)
    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header X-Forwarded-Host $host;
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_read_timeout 60s;
        proxy_no_cache 1;
        proxy_cache_bypass 1;
        add_header Cache-Control "no-store, must-revalidate" always;
    }
}
