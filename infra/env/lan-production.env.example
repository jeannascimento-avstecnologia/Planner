# Template: apps/web/.env.local no servidor Linux (producao LAN segura)
# Copie para apps/web/.env.local no servidor. chmod 600. NUNCA commitar.
#
# Runbook: docs/70-ops/linux-lan-secure-deploy.md

# --- Supabase Cloud (anon e suficiente no Next.js; RLS protege dados) ---
NEXT_PUBLIC_SUPABASE_URL=https://mkpjtvpstdjfmidvruor.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY>

# URL publica HTTPS (mesma do nginx + Supabase Auth URLs)
NEXT_PUBLIC_APP_URL=https://agify.avstecnologia.local

# --- Resend (convites por email) ---
RESEND_API_KEY=re_...
RESEND_FROM=Agify <noreply@suaempresa.com>

# --- Upstash (recomendado: rate limit de convites) ---
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# --- Opcionais ---
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# TIFLUX_API_URL=https://api.tiflux.com/api/v2
# TIFLUX_API_TOKEN=

# NAO coloque SUPABASE_SERVICE_ROLE_KEY neste host.
# Segredos de Edge Functions ficam no Supabase Dashboard.
