# Template: conteudo do GitHub Secret ENV_FILE_WEB (environment production)
# NAO commitar valores reais. Copie para Settings -> Environments -> production -> Secrets
#
# Runbook: docs/70-ops/vps-deploy.md

# --- Supabase Cloud ---
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY>

# --- App (mesmo host de APP_HOST_FRONTEND no GitHub Environment) ---
NEXT_PUBLIC_APP_URL=https://apify.prosperfy.com.br

# --- Cloudinary ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<CLOUD_NAME>
CLOUDINARY_API_KEY=<API_KEY>
CLOUDINARY_API_SECRET=<API_SECRET>

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=<REDIS_REST_URL>
UPSTASH_REDIS_REST_TOKEN=<REDIS_REST_TOKEN>

# --- Resend ---
RESEND_API_KEY=<RESEND_KEY>
RESEND_FROM=Agify <noreply@seudominio.com.br>

# --- Web Push (opcional) ---
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# --- Tiflux ---
# Token por board no DB (RPC). NUNCA setar TIFLUX_API_TOKEN em producao (P0.2).
# TIFLUX_API_URL=https://api.tiflux.com/api/v2

NODE_ENV=production
