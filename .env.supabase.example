# ==========================================================================
# Chaves do projeto Supabase Cloud (copie para .env.supabase na raiz)
# NUNCA commitar .env.supabase — esta e apenas a plantilla.
# Dashboard: Settings -> API
# Runbook: docs/70-ops/supabase-cloud-dev.md
# ==========================================================================

# URL do projeto (ex: https://abcdefghijklmnop.supabase.co)
SUPABASE_URL=https://<PROJECT_REF>.supabase.co

# Opcional se usar `supabase link` sem preencher URL manualmente
# SUPABASE_PROJECT_REF=<PROJECT_REF>

# Chaves API (Settings -> API)
SUPABASE_ANON_KEY=<ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY>
