# ==========================================================================
# NextGen Planner - variaveis de ambiente (apps/web/.env.local)
# Dev local: use Supabase CLOUD (sem Docker). Ver docs/70-ops/supabase-cloud-dev.md
# Gere automaticamente: npm run supabase:env (a partir de .env.supabase ou CLI linkada)
# NUNCA commitar segredos. Service role / API secret sao SOMENTE server-side.
# ==========================================================================

# --- Supabase Cloud (cliente) ---
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<ANON_KEY>

# --- Supabase (servidor / Edge Functions) — NUNCA NEXT_PUBLIC_ ---
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY>

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Google OAuth: configurar no Supabase Dashboard (sem vars GOOGLE_* no app). Ver docs/20-architecture/google-oauth.md

# --- Cloudinary (upload assinado: secret SO no servidor) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<CLOUD_NAME>
CLOUDINARY_API_KEY=<API_KEY>
CLOUDINARY_API_SECRET=<API_SECRET>

# --- Upstash Redis (cache / rate-limit / presence) ---
UPSTASH_REDIS_REST_URL=<REDIS_REST_URL>
UPSTASH_REDIS_REST_TOKEN=<REDIS_REST_TOKEN>

# --- Tiflux (API v2 — somente servidor / Edge Function) ---
TIFLUX_API_URL=https://api.tiflux.com/api/v2
TIFLUX_API_TOKEN=<TIFLUX_BEARER_TOKEN>

NEXT_PUBLIC_VAPID_PUBLIC_KEY=<VAPID_PUBLIC_KEY>
VAPID_PRIVATE_KEY=<VAPID_PRIVATE_KEY>
